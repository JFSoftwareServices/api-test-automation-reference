{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "description": "Schema for a single user resource from JSONPlaceholder /users",
  "type": "object",
  "required": ["id", "name", "username", "email"],
  "properties": {
    "id":       { "type": "integer", "description": "Unique user identifier" },
    "name":     { "type": "string",  "minLength": 1 },
    "username": { "type": "string",  "minLength": 1 },
    "email":    { "type": "string",  "format": "email" },
    "phone":    { "type": ["string", "null"] },
    "website":  { "type": ["string", "null"] },
    "address": {
      "type": "object",
      "properties": {
        "street":  { "type": "string" },
        "suite":   { "type": "string" },
        "city":    { "type": "string" },
        "zipcode": { "type": "string" },
        "geo": {
          "type": "object",
          "properties": {
            "lat": { "type": "string" },
            "lng": { "type": "string" }
          }
        }
      }
    },
    "company": {
      "type": "object",
      "properties": {
        "name":        { "type": "string" },
        "catchPhrase": { "type": "string" },
        "bs":          { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}