# envs/dev.env
#
# Docker environment variables for the development test container.
#
# Used by:
#   docker compose --profile dev up tests-dev
#
# These variables are injected into the container at runtime and may be used
# by the application to is used by the application to select the active environment configuration.
#
# envs/dev.env
#
# Docker environment variables for the development test container.
# Used by: docker compose --profile dev up tests-dev

ENV=dev

# ==============================
# Test Execution
# ==============================
SUITE=testng.xml

# ==============================
# Base URLs
# ==============================
BASE_URL_JSON=https://jsonplaceholder.typicode.com
BASE_URL_XML=https://jsonplaceholder.typicode.com

# ==============================
# Logging Flags
# ==============================
LOG_REQUESTS=true
LOG_RESPONSES=false