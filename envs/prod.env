# envs/deprodv.env — Docker environment variables for the prod test container
# Used by: docker-compose --profile prod up tests-prod
# These override config.properties at runtime without rebuilding the image.
ENV=prod
BASE_URL_JSON=https://jsonplaceholder.typicode.com
BASE_URL_XML=https://jsonplaceholder.typicode.com
SUITE=testng-parallel.xml
LOG_REQUESTS=true
LOG_RESPONSES=true
